    while true do
        local rb = parseValue((Player.leaderstats:FindFirstChild("Rebirths") or Player.leaderstats:FindFirstChild("\240\159\152\135Rebirths")).Value)
        
        if getgenv().Config.ModeEvent then
            -- EVENT MODE
            if rb >= 0 and rb < 999 then
                TravelRemote:InvokeServer("Event", false, "Event")
                task.wait(300) -- Đợi 5 phút
                EggRemote:InvokeServer("Mushroom Egg", "1", {}, nil)
            end
