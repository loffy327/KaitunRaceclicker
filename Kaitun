-- AUTO WIN (FLY)
task.spawn(function()
    local startPos = Vector3.new(-2562, -8, 0)
    local endPos = Vector3.new(-584062, -8, 0)
    local speed = 80000000
    
    while true do
        local Character = Player.Character or Player.CharacterAdded:Wait()
        local HRP = Character:WaitForChild("HumanoidRootPart")
        
        -- Thêm BodyVelocity để giữ cao độ
        local bv = HRP:FindFirstChild("KaitunBV") or Instance.new("BodyVelocity")
        bv.Name = "KaitunBV"
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = HRP

        HRP.CFrame = CFrame.new(startPos)
        task.wait(0.1)
        
        local direction = (endPos - startPos).Unit
        local distance = (endPos - startPos).Magnitude
        local current = 0
        
        while current < distance do
            local dt = RunService.Heartbeat:Wait()
            current = math.min(current + speed * dt, distance)
            HRP.CFrame = CFrame.new(startPos + direction * current)
        end
        task.wait(0.1)
    end
end)

-- EVENT MODE & TRAVEL
task.spawn(function()
    local TravelRemote = ReplicatedStorage.Packages.Knit.Services.WorldService.RF.Travel
    local EggRemote = ReplicatedStorage.Packages.Knit.Services.EggService.RF.Open
    local lastWorld = ""
    
    while true do
        local rbObj = getLeaderstat("Rebirths")
        local rb = rbObj and parseValue(rbObj.Value) or 0
        local isEvent = getgenv().Config and getgenv().Config["ModeEvent"]

        if isEvent then
            -- Logic Event
            if rb >= 0 and rb < 999 then
                TravelRemote:InvokeServer("Event", false, "Event")
                
                -- Đợi 5 phút sau khi bật script mới mở trứng
                if (os.time() - startTime) >= 300 then
                    EggRemote:InvokeServer("Mushroom Egg", "1", {}, nil)
                end
            end
        else
            -- Logic TP Island
            if rb >= 1 and rb < 2 and lastWorld ~= "Space" then
                TravelRemote:InvokeServer("Space", false, nil)
                lastWorld = "Space"
            elseif rb >= 3 and rb < 4 and lastWorld ~= "Ocean" then
                TravelRemote:InvokeServer("Ocean", false, nil)
                lastWorld = "Ocean"
