-- [[ HÀM XỬ LÝ LOGIC SỐ ]] --
local function parseValue(val)
    local str = tostring(val):gsub(",", ""):gsub(" ", "")
    local suffix = str:sub(-1):upper()
    local num = tonumber(str:match("[%d%.]+")) or 0
    if suffix == "K" then return num * 1000
    elseif suffix == "M" then return num * 1000000
    elseif suffix == "B" then return num * 1000000000 end
    return tonumber(str) or 0
end

