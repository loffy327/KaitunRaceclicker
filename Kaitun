-- 2. Auto Win (Fly)
task.spawn(function()
    local HRP = Player.Character:WaitForChild("HumanoidRootPart")
    local startPos = Vector3.new(-2562, -8, 0)
    local endPos = Vector3.new(-584062, -8, 0)
    local speed = 80000000 

    local bv = Instance.new("BodyVelocity", HRP)
    bv.Velocity = Vector3.zero
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

    while true do
        HRP.CFrame = CFrame.new(startPos)
        task.wait(0.1)
        local direction = (endPos - startPos).Unit
        local distance = (endPos - startPos).Magnitude
        local currentDistance = 0
        while currentDistance < distance do
            local dt = task.wait()
            currentDistance = math.min(currentDistance + (speed * dt), distance)
            HRP.CFrame = CFrame.new(startPos + direction * currentDistance)
        end
        task.wait(0)
    end
end)

